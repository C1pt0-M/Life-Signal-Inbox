# Life Signal Inbox AI 模型配置示例
# 复制为 backend/.env 后再填写真实密钥。
# backend/.env 已被 .gitignore 忽略，不要提交真实密钥。

LIFE_SIGNAL_AI_PROVIDER=openai-compatible
LIFE_SIGNAL_AI_API_KEY=你的模型服务密钥
LIFE_SIGNAL_AI_MODEL=gpt-4o-mini
LIFE_SIGNAL_AI_BASE_URL=https://api.openai.com/v1

# 可选：配置视觉模型后，上传图片会优先走多模态模型；不配置时回落到本地 PaddleOCR
LIFE_SIGNAL_VISION_MODEL=
LIFE_SIGNAL_VISION_PROVIDER=openai-compatible
LIFE_SIGNAL_VISION_API_KEY=
LIFE_SIGNAL_VISION_BASE_URL=https://api.openai.com/v1
